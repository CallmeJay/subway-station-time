.sched {
  width: 100%;
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* 自定义导航 */
.nav-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  background: var(--bg);
  z-index: 11;
  border-bottom: 1rpx solid var(--hairline);
  display: flex;
  align-items: stretch;
}
.nav-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: 0.05em;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-right: 180rpx;
  box-sizing: border-box;
}
.nav-back {
  position: absolute;
  left: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 12;
}
.nav-back .back-arrow {
  font-size: 56rpx;
  color: var(--ink);
  font-weight: 300;
  line-height: 1;
  margin-top: -8rpx;
}

/* head */
.head {
  flex-shrink: 0;
  padding: 24rpx 36rpx 24rpx;
  background: var(--card);
  margin: 0 16rpx;
  border-radius: 32rpx;
  margin-top: 0;
  box-shadow: var(--shadow-sm);
}
.head-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.line-pill {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 800;
}
.line-name {
  font-size: 24rpx;
  color: var(--ink-2);
  font-weight: 600;
  letter-spacing: 0.05em;
}
.head-station {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: 0.02em;
  line-height: 1;
}
.head-direction {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: var(--ink-2);
  font-weight: 500;
}
.head-direction .dir-arrow {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent);
}
.head-direction .dir-target {
  font-weight: 700;
  color: var(--ink);
}
.head-stat {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: var(--ink-3);
}
.head-stat-now {
  font-feature-settings: "tnum" 1;
  color: var(--accent);
  font-weight: 700;
}

.fixed-end {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: var(--row-active);
  border-radius: 100rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: var(--ink-2);
  font-weight: 500;
}
.fe-dot {
  width: 12rpx; height: 12rpx;
  border-radius: 50%;
}
.fe-name { font-weight: 700; color: var(--ink); }

/* 日类型切换 */
.dt-toggle {
  flex-shrink: 0;
  margin: 24rpx 16rpx 16rpx;
  background: var(--card);
  border-radius: 32rpx;
  padding: 6rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rpx;
  box-shadow: var(--shadow-sm);
}
.dt-btn {
  text-align: center;
  padding: 18rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink-3);
  border-radius: 26rpx;
  transition: all 0.15s ease;
}
.dt-btn.active {
  background: var(--ink);
  color: var(--bg);
}

/* 数据来源诚实标注 */
.data-note {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin: 0 24rpx 16rpx;
  padding: 14rpx 18rpx;
  background: var(--row-active);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: var(--ink-3);
  line-height: 1.5;
  font-weight: 500;
}
.dn-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: var(--ink-3);
  color: var(--card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 800;
  font-style: italic;
  flex-shrink: 0;
  margin-top: 2rpx;
}

/* schedule list (页面自然滚动, 不用 scroll-view) */
.schedule-list {
  padding: 0 16rpx;
}

/* hour block */
.hour-block {
  background: var(--card);
  border-radius: 32rpx;
  padding: 24rpx 28rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
}
.hour-block.is-current {
  border: 2rpx solid var(--accent);
  padding: 22rpx 26rpx 26rpx;
}

.hour-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.hour-label {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--ink);
  letter-spacing: 0.05em;
  font-feature-settings: "tnum" 1;
}
.hour-block.is-current .hour-label { color: var(--accent); }
.hour-count {
  font-size: 22rpx;
  color: var(--ink-3);
  font-weight: 500;
}

/* minute grid */
.minute-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.minute-chip {
  background: var(--row-active);
  border-radius: 16rpx;
  padding: 14rpx 8rpx;
  text-align: center;
  position: relative;
  transition: all 0.15s ease;
}
.minute-chip.is-past {
  opacity: 0.35;
}
.minute-chip.is-now {
  background: var(--c, var(--accent));
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}
.minute-chip.is-now .chip-min,
.minute-chip.is-now .chip-sub,
.minute-chip.is-now .chip-origin { color: #fff; }

.chip-main {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}
.chip-min {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--ink);
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.02em;
  line-height: 1;
}
.chip-origin {
  font-size: 18rpx;
  font-weight: 800;
  color: var(--seat);
  background: rgba(0, 149, 94, 0.15);
  padding: 2rpx 6rpx;
  border-radius: 100rpx;
  margin-left: 2rpx;
}
.minute-chip.is-now .chip-origin {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
}
.chip-sub {
  font-size: 18rpx;
  color: var(--ink-3);
  margin-top: 4rpx;
  font-weight: 500;
  letter-spacing: 0.02em;
}

/* empty */
.empty {
  text-align: center;
  padding: 200rpx 0;
}
.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 22rpx;
  color: var(--ink-3);
}
.footer-pad { height: 80rpx; }
